# Device Inventory Collector - Device List
# Copy to devices.yaml and add your devices
#
# SECURITY: Never commit this file with real passwords!
# Use environment variable: export DEVICE_PASSWORD=yourpass
# Or you'll be prompted when running the script

devices:
  # Juniper device
  - ip: "192.168.1.1"
    device_type: "juniper_junos"
    username: "netadmin"
    # Password provided via prompt or DEVICE_PASSWORD env var

  # Cisco IOS-XR device
  - ip: "192.168.1.2"
    device_type: "cisco_xr"
    username: "netadmin"

  # Arista device
  - ip: "192.168.1.3"
    device_type: "arista_eos"
    username: "admin"

# Supported device_type values (Netmiko):
#   juniper_junos
#   cisco_ios
#   cisco_xe
#   cisco_xr
#   arista_eos
#   cisco_nxos
